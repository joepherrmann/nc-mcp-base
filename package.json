{
  "name": "nc-mcp-base",
  "version": "0.1.0",
  "description": "Nextcloud-OIDC auth + transport scaffolding for self-hosted MCP servers. Drop in stdio + Streamable HTTP transport, OAuth metadata, and Bearer middleware that validates against any Nextcloud instance.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joepherrmann/nc-mcp-base.git"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "nextcloud",
    "oauth",
    "oidc",
    "streamable-http"
  ]
}
